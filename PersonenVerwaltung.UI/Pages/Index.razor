@page "/"
@using PersonenVerwaltung.UI.Services
@inject PersonApiService Api
@inject NavigationManager Nav

<PageTitle>Personenverwaltung</PageTitle>

<h1>Personenverwaltung</h1>

<div class="search-bar">
    <input type="text"
           placeholder="Name oder Vorname suchen..."
           @bind="searchName"
           @bind:event="oninput" />
    <button @onclick="LoadPersonen">Personen laden</button>
</div>

@if (isLoading)
{
    <p>Wird geladen...</p>
}
else if (errorMessage != null)
{
    <p class="error">@errorMessage</p>
}
else if (personen.Count == 0 && hasLoaded)
{
    <p>Keine Personen gefunden.</p>
}
else if (personen.Count > 0)
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Vorname</th>
                <th>Geburtsdatum</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in personen)
            {
                <tr @onclick="() => Nav.NavigateTo($\"/persons/{p.Id}\")" style="cursor:pointer">
                    <td>
                        @if (editingId == p.Id)
                        {
                            <input @bind="editName" @onclick:stopPropagation="true" />
                        }
                        else
                        {
                            @p.Name
                        }
                    </td>
                    <td>
                        @if (editingId == p.Id)
                        {
                            <input @bind="editVorname" @onclick:stopPropagation="true" />
                        }
                        else
                        {
                            @p.Vorname
                        }
                    </td>
                    <td>@p.Geburtsdatum.ToString("dd.MM.yyyy")</td>
                    <td @onclick:stopPropagation="true">
                        @if (editingId == p.Id)
                        {
                            <button @onclick="() => SavePerson(p.Id)">Sichern</button>
                            <button @onclick="CancelEdit">Abbrechen</button>
                        }
                        else
                        {
                            <button @onclick="() => StartEdit(p)">Bearbeiten</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string searchName = string.Empty;
    private List<PersonListItem> personen = new();
    private bool isLoading;
    private bool hasLoaded;
    private string? errorMessage;

    // Inline-Bearbeitung
    private int? editingId;
    private string editName = string.Empty;
    private string editVorname = string.Empty;

    private async Task LoadPersonen()
    {
        isLoading = true;
        errorMessage = null;
        hasLoaded = false;
        try
        {
            personen = await Api.GetPersonenAsync(searchName);
            hasLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Laden: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartEdit(PersonListItem p)
    {
        editingId = p.Id;
        editName = p.Name;
        editVorname = p.Vorname;
    }

    private void CancelEdit() => editingId = null;

    private async Task SavePerson(int id)
    {
        var success = await Api.UpdatePersonAsync(id, editName, editVorname);
        if (success)
        {
            editingId = null;
            await LoadPersonen();
        }
        else
        {
            errorMessage = "Fehler beim Speichern.";
        }
    }
}
